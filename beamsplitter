def NSfield2(struct, beams, window, onlyreflected=None):

    if not isinstance(beams, (list, tuple)):
        beams = [beams]

    I_total = 0

    for beam in beams:

        lam = beam.wavelength
        Epsilon, Mu = struct.polarizability(lam)

        thickness = np.array(struct.thickness)
        Dphi = beam.distance
        w = beam.waist
        pol = beam.polarization
        d = window.width
        theta = beam.incidence
        pixDphi = Dphi/d
        C = window.C

        ny = np.floor(thickness / window.py)
        nx = window.nx
        Type = struct.layer_type

        transmission = 1
        reflexion = 1
        if onlyreflected:
            transmission = 0
        elif onlyreflected == False:
            reflexion = 0

        nmod = int(np.floor(0.83660 * d / w))

        l = lam / d
        w = w / d
        thickness = thickness / d

        if pol == 0:
            f = Mu
        else:
            f = Epsilon

        k_0 = 2 * pi / l

        En = []

        g = len(struct.layer_type) - 1

        nmodvect = np.arange(-nmod, nmod + 1)

        gauss = np.exp(-(w**2) * pi**2 * nmodvect**2)
        phase = np.exp(-2 * 1j * pi * nmodvect * C)

        X = gauss * phase

        layer_k = np.sqrt(Epsilon[Type] * Mu[Type] * k_0**2)

        T = np.zeros((2 * g + 2, 2, 2), dtype=complex)
        T[0] = [[0, 1], [1, 0]]

        for nm in np.arange(2 * nmod + 1):

            n_0 = np.sqrt(Epsilon[Type[0]] * Mu[Type[0]])
            alpha = n_0 * k_0 * np.sin(theta) + 2 * pi * (nm - nmod)

            gamma = np.sqrt(layer_k**2 - np.ones(g + 1) * alpha**2)

            if np.real(Epsilon[Type[0]]) < 0 and np.real(Mu[Type[0]]) < 0:
                gamma[0] = -gamma[0]

            if g > 2:
                im_sign = np.imag(gamma[1:g-1]) < 0
                gamma[1:g-1] *= (1 - 2 * im_sign)

            if (
                np.real(Epsilon[Type[g]]) < 0
                and np.real(Mu[Type[g]]) < 0
                and np.real(np.sqrt(layer_k[g]**2 - alpha**2)) != 0
            ):
                gamma[g] = -np.sqrt(layer_k[g]**2 - alpha**2)
            else:
                gamma[g] = np.sqrt(layer_k[g]**2 - alpha**2)

            if (np.imag(gamma[0]) > 0) and (pixDphi > 0):
                gamma[0] = 0

            gf = gamma / f[Type]

            for k in range(g):

                t = np.exp(1j * gamma[k] * thickness[k])

                T[2*k+1] = np.array([[0, t], [t, 0]])

                b1 = gf[k]
                b2 = gf[k+1]

                T[2*k+2] = np.array([[b1-b2, 2*b2],
                                     [2*b1, b2-b1]]) / (b1 + b2)

            t = np.exp(1j * gamma[g] * thickness[g])
            T[2*g+1] = np.array([[0, t], [t, 0]])

            H = np.zeros((len(T)-1, 2, 2), dtype=complex)
            A = np.zeros((len(T)-1, 2, 2), dtype=complex)

            H[0] = T[2*g+1]
            A[0] = T[0]

            for k in range(len(T)-2):
                A[k+1] = cascade(A[k], T[k+1])
                H[k+1] = cascade(T[len(T)-k-2], H[k])

            I = np.zeros((2, 2, 2), dtype=complex)

            for k in range(2):
                I[k] = np.array(
                    [
                        [A[k][1,0], A[k][1,1]*H[len(T)-k-2][0,1]],
                        [A[k][1,0]*H[len(T)-k-2][0,0], H[len(T)-k-2][0,1]],
                    ]
                ) / (1 - A[k][1,1]*H[len(T)-k-2][0,0])

            h = 0
            if onlyreflected == True :
                for m in range(int(ny[0])):
                    h += float(thickness[0]) / ny[0]
            
                E = transmission*(I[0][0,0]*np.exp(1j*gamma[0]*h)) + \
                        reflexion*(I[1][1,0]*np.exp(1j*gamma[0]*(thickness[0]-h)))
            
                E *= np.exp(1j * alpha * np.arange(0, nx) / nx)
                E *= np.exp(-1j * gamma[0] * pixDphi)
                
            if onlyreflected == False:
                for m in range(int(ny[g])):
                    h += float(thickness[g]) / ny[g]

                E = transmission*(I[0][0,0]*np.exp(1j*gamma[g]*h)) + \
                    reflexion*(I[1][1,0]*np.exp(1j*gamma[g]*(thickness[g]-h)))

                E *= np.exp(1j * alpha * np.arange(0, nx) / nx)
                E *= np.exp(-1j * gamma[g] * pixDphi)
            En.append(X[int(nm)] * E)

        E=sum(En)

        E=sum(En)
        I_total+=np.abs(E)**2

    return I_total

def profil_R_2(struct, beams, window, type = "abs"):
    """
    Args:
        struct (Structure): the structure used
        beam (Beam): the beam used
        window (Window): the window used (big enough to avoid resonances during computation using the function "field")
        type (str, optional): "abs" by default, return the amplitude field. If changed the entire field will be returned (complex value)

    Returns:
        Field (Array): return the reflected field along the first interface
    """
    E = NSfield2(struct, beams, window,True) # True + NSfield
    if type == "abs":
        inter = np.sqrt(E)
    else:
        inter = E
    return inter


def QODE2_batch(
    f_cout_batch,
    budget,
    X_min,
    X_max,
    f1=0.9,
    f2=0.8,
    cr=0.5,
    progression=False,
    cout_seuil=0.001,
    patience=None,
    tol=1e-6,
    n_jobs=-2,
    pop_initiale=None,
):
    n = X_min.size

    if pop_initiale is not None:
        pop_initiale = np.array(pop_initiale)
        population = len(pop_initiale)
        omega = pop_initiale.copy()
    else:
        omega = np.zeros((population, n))
        c = (X_max + X_min) / 2
        for k in range(0, population, 2):
            v1 = X_min + (X_max - X_min) * np.random.random(n)
            delta = 2 * (c - v1) * np.random.random(n)
            v2 = v1 + delta
            omega[k] = v1
            omega[k + 1] = v2

    cost = np.array(f_cout_batch(omega, n_jobs=n_jobs))

    who = np.argmin(cost)
    best = omega[who]

    evaluation = population
    convergence = [cost[who]]
    historique_pop = [cost.copy()]
    generation = 0

    meilleur_cout = cost[who]
    generations_sans_amelioration = 0
    raison_arret = "budget épuisé"

    # --- Barre de progression globale sur le budget ---
    pbar = tqdm(total=budget, initial=evaluation, desc="QODE batch", unit="éval", position=0)

    while evaluation < budget - population:

        if cout_seuil is not None and cost[who] < cout_seuil:
            raison_arret = f"seuil atteint ({cost[who]:.6f} < {cout_seuil})"
            break
        if patience is not None and generations_sans_amelioration >= patience:
            raison_arret = f"stagnation ({patience} générations sans amélioration > {tol})"
            break

        trial_vectors = []
        valid_mask = []
        for k in range(population):
            crossover = np.random.random(n) < cr
            pop_1 = omega[np.random.randint(population)]
            pop_2 = omega[np.random.randint(population)]
            rand_step = pop_1 - pop_2
            best_step = best - omega[k]

            new_param = omega[k] + f1 * rand_step + f2 * best_step
            X = new_param * (1 - crossover) + omega[k] * crossover

            in_bounds = np.prod((X >= X_min) * (X <= X_max))
            valid_mask.append(bool(in_bounds))
            trial_vectors.append(X if in_bounds else omega[k])

        trial_costs = f_cout_batch(trial_vectors, n_jobs=n_jobs)

        n_eval_gen = sum(valid_mask)
        evaluation += n_eval_gen
        pbar.update(n_eval_gen)

        for k in range(population):
            if valid_mask[k] and trial_costs[k] < cost[k]:
                cost[k] = trial_costs[k]
                omega[k] = trial_vectors[k]

        generation += 1
        who = np.argmin(cost)
        best = omega[who]
        convergence.append(cost[who])
        historique_pop.append(cost.copy())

        pbar.set_postfix(best=f"{cost[who]:.6f}", gen=generation)

        if patience is not None:
            if meilleur_cout - cost[who] > tol:
                meilleur_cout = cost[who]
                generations_sans_amelioration = 0
            else:
                generations_sans_amelioration += 1

    pbar.close()
    print(f"Arrêt : {raison_arret} | générations : {generation} | évaluations : {evaluation}")
    return [best, convergence, historique_pop]

